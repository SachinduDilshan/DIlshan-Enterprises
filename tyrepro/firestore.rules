rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function isAdminOrSalesRep() {
      return isAuth() && getRole() in ['admin', 'sales_rep'];
    }

    // Users — anyone authenticated can read their own profile
    match /users/{uid} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Shops — admin and sales_rep can add/edit/delete
    match /shops/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Products — admin and sales_rep can manage
    match /products/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Stock — admin and sales_rep can manage
    match /stock/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Invoices — admin and sales_rep can create and update
    match /invoices/{id} {
      allow read: if isAuth();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
      match /items/{itemId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdminOrSalesRep();
      }
    }

    // Cheques — admin and sales_rep can manage
    match /cheques/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // UC Returns — admin and sales_rep can manage
    match /ucReturns/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Stock transfers — admin and sales_rep
    match /stockTransfers/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Dispatches — admin and sales_rep plan; driver can update stop status
    match /dispatches/{id} {
      allow read: if isAuth();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
      match /stops/{stopId} {
        allow read: if isAuth();
        allow create, update: if isAuth(); // driver can mark stops
        allow delete: if isAdmin();
      }
    }

    // Warehouses — read all, write admin only
    match /warehouses/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Counters — read and write for authenticated users
    match /counters/{id} {
      allow read, write: if isAuth();
    }

    // System alerts — read all auth, write admin only
    match /systemAlerts/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Alert settings per user
    match /alertSettings/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }
  }
}
