rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function isAdminOrSalesRep() {
      return isAuth() && getRole() in ['admin', 'sales_rep'];
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /shops/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    match /products/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Stock — admin and sales_rep can read and write freely
    match /stock/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    // Stock adjustments audit log
    match /stockAdjustments/{id} {
      allow read: if isAuth();
      allow create: if isAdminOrSalesRep();
      allow update, delete: if isAdmin();
    }

    match /invoices/{id} {
      allow read: if isAuth();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
      match /items/{itemId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdminOrSalesRep();
      }
    }

    match /cheques/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    match /ucReturns/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    match /stockTransfers/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrSalesRep();
    }

    match /dispatches/{id} {
      allow read: if isAuth();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
      match /stops/{stopId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if isAdmin();
      }
    }

    match /warehouses/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /counters/{id} {
      allow read, write: if isAuth();
    }

    match /systemAlerts/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /alertSettings/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }
  }
}
